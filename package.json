{
    "name": "railway-pg-s3-backup",
    "version": "0.0.1",
    "description": "A simple Bun app to backup PostgreSQL databases to an S3 bucket",
    "keywords": [],
    "license": "MIT",
    "author": "Faraz Patankar",
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "start": "bun run src/index.ts",
        "build": "bun build ./src/index.ts --outdir=./dist --target=node",
        "typecheck": "bun run build",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.901.0",
        "@aws-sdk/lib-storage": "^3.901.0",
        "envsafe": "^2.0.3",
        "filesize": "^10.1.1"
    },
    "devDependencies": {
        "bun-types": "latest",
        "oxfmt": "^0.37.0"
    }
}
